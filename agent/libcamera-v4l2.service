[Unit]
Description=libcamera-v4l2 – CSI kamera jako /dev/video0 (jen pro opencv backend)
Before=whiteboard-agent.service

[Service]
Type=simple
# Na Debian Trixie může chybět binárka – pak použij picamera2 backend
ExecStart=/usr/bin/libcamera-v4l2 --camera 0
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
